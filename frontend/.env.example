# Frontend (Vite) configuration.
# Only the backend base URL belongs here. It is baked into the static bundle at build time.
VITE_API_BASE_URL=http://localhost:8080

# DO NOT put any AI/LLM API keys here. The frontend bundle is public; anything in a VITE_* variable
# ships to the browser. OpenAI/Anthropic keys are backend-only — see backend/.env.example.
