  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "^2.1.9"
  }
