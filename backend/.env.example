# Backend configuration example. Copy to a real .env (which is git-ignored) or set as real
# environment variables in your deployment. NEVER commit real keys — these are placeholders only.

# --- Database / server ---
DATABASE_URL=jdbc:postgresql://localhost:5432/budgetspace
DATABASE_USERNAME=budgetspace
DATABASE_PASSWORD=change-me
SERVER_PORT=8080
# Comma-separated allowed frontend origins (required in the prod profile).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Catalog / admin (Sprint 10.9) ---
BUDGETSPACE_REAL_CATALOG_SEED_ENABLED=true
BUDGETSPACE_ADMIN_ENDPOINTS_ENABLED=true

# --- AI / LLM (Sprint 10.10) — BACKEND ONLY. Never expose these to the frontend. ---
# Master switch. Off by default → deterministic rule-based parsing, no external calls, no cost.
BUDGETSPACE_AI_ENABLED=false
# Which provider to use when enabled: off | openai | anthropic
BUDGETSPACE_LLM_PROVIDER=off
# API keys (placeholders — replace with real values in your secret store, not in git):
OPENAI_API_KEY=sk-REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Optional: override the model (defaults to a cheap "mini" model per provider).
BUDGETSPACE_LLM_MODEL=
BUDGETSPACE_LLM_TIMEOUT_SECONDS=15
BUDGETSPACE_LLM_MAX_OUTPUT_TOKENS=700

# --- AI cost / rate guardrails (Sprint 10.10) ---
BUDGETSPACE_AI_MONTHLY_BUDGET_USD=20
BUDGETSPACE_AI_MAX_REQUESTS_PER_DAY=100
BUDGETSPACE_AI_MAX_REQUESTS_PER_SESSION=10

# --- Design assistant (Sprint 10.8) ---
BUDGETSPACE_DESIGN_ASSISTANT_LLM_ENABLED=false
BUDGETSPACE_DESIGN_ASSISTANT_MODEL=claude-opus-4-8
