# BudgetSpace backend configuration — copy to a real .env (git-ignored) or set as real environment variables
# in your host's secret store. NEVER commit real values; these are placeholders / safe defaults only.
#
# Values below are PROD-SAFE by default. For local dev you usually don't need this file at all — the dev
# docker-compose.override.yml already supplies dev values. See DEPLOY.md for the full, ordered launch checklist.

# --- Spring profile (LOAD-BEARING) -----------------------------------------------------------------------------
# `prod` flips every safe default on: non-destructive schema (ddl-auto=validate), admin endpoints OFF, Secure
# cookie, and a required explicit CORS origin. The prod Docker image bakes this in; set it here too if you run
# the jar directly. WITHOUT it the base profile wins (ddl-auto=create → wipes the DB on every restart).
SPRING_PROFILES_ACTIVE=prod

# --- Database / server -----------------------------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/budgetspace
DATABASE_USERNAME=budgetspace
DATABASE_PASSWORD=change-me-to-a-real-password
SERVER_PORT=8080
# Flyway (V1 baseline + versioned migrations) creates/migrates the prod schema; ddl-auto=validate just checks it
# matches the entities. Leave this at validate — ship a migration for schema changes, never set create/update.
HIBERNATE_DDL_AUTO=validate
# Comma-separated allowed frontend origin(s). REQUIRED in prod — the app fails fast at boot if missing.
CORS_ALLOWED_ORIGINS=https://yourdomain
# Session cookie is Secure (HTTPS only) in prod.
BUDGETSPACE_AUTH_COOKIE_SECURE=true
# Sprint 10.168: number of TRUSTED reverse-proxy hops between the app and the public internet. Used to read the
# real client IP from X-Forwarded-For WITHOUT trusting client-supplied entries — this drives the per-IP rate limit
# AND the per-guest AI daily cap (so a guest can't reset their AI allowance just by clearing cookies / a new
# incognito window). Railway/Render/Fly = 1 (the default). Add +1 for each extra proxy you put in front (e.g. a
# CDN like Cloudflare in front of Railway → 2). Setting it too HIGH falls back to the socket address (safe); too
# LOW would trust one spoofable hop, so match it to your actual chain.
BUDGETSPACE_TRUSTED_PROXY_COUNT=1
# SameSite for the session cookie. Leave Lax when the frontend and backend share a registrable domain
# (yourdomain + api.yourdomain — recommended). Set None ONLY for a split-host deploy (frontend and backend on
# unrelated domains, e.g. vercel.app + railway.app), where Lax would silently break sign-in. None forces Secure on.
BUDGETSPACE_AUTH_COOKIE_SAMESITE=Lax

# --- Catalog / admin -------------------------------------------------------------------------------------------
BUDGETSPACE_REAL_CATALOG_SEED_ENABLED=true
# Rolling FRESHNESS re-check: ON in prod (application-prod.yml). Re-verifies the stalest products' live prices
# every 6h so stored prices self-heal over time. Set false to pause. (cron/batch below are optional overrides.)
BUDGETSPACE_CATALOG_FRESHNESS_ENABLED=true
# BUDGETSPACE_CATALOG_FRESHNESS_CRON=0 20 */6 * * *
# BUDGETSPACE_CATALOG_FRESHNESS_BATCH_SIZE=60
# Weekly catalog HEALTH AUDIT: logs a summary and WARNs when too much of the catalog is stale.
BUDGETSPACE_CATALOG_AUDIT_ENABLED=true
# BUDGETSPACE_CATALOG_AUDIT_CRON=0 0 4 * * 1
# BUDGETSPACE_CATALOG_AUDIT_STALE_THRESHOLD=0.2
# Dev collector/import/catalog-health endpoints. MUST stay false in prod (the prod profile also forces this off).
BUDGETSPACE_ADMIN_ENDPOINTS_ENABLED=false

# --- Auth (Google Sign-In, server-side OAuth redirect flow) ----------------------------------------------------
# Sprint 10.149: sign-in is the SERVER-SIDE OAuth authorization-code (redirect) flow — reliable in every browser
# (immune to the GIS One-Tap/FedCM per-browser cooldown). Set ALL THREE for Google sign-in to be offered:
#   1) the PUBLIC client id, 2) the client SECRET (keep secret — only in this gitignored .env), 3) the redirect URI
#      which MUST be registered in the OAuth client's "Authorized redirect URIs" (Google Cloud Console).
BUDGETSPACE_GOOGLE_CLIENTID=
BUDGETSPACE_GOOGLE_CLIENTSECRET=
# Backend callback. Dev: http://localhost:8090/api/auth/google/callback  ·  Prod: https://api.yourdomain/api/auth/google/callback
BUDGETSPACE_GOOGLE_REDIRECT_URI=
# Where to return the browser after sign-in (the frontend app URL). Dev: http://localhost:5180  ·  Prod: https://yourdomain
BUDGETSPACE_AUTH_POST_LOGIN_REDIRECT=

# --- Billing (Stripe) ------------------------------------------------------------------------------------------
# Use LIVE keys in prod. Blank → billing dormant (the Plus CTA falls back to the waitlist).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PLUS_PRICE_ID=
# Webhook signing secret (Stripe Dashboard → Webhooks). The webhook is the prod source of truth for plan changes.
STRIPE_WEBHOOK_SECRET=

# --- Beta mode / one-time Design Session model (Sprint 10.105) -------------------------------------------------
# true (default) = FREE BETA: all premium "Design Session" features are unlocked for free + a beta notice shows;
# no prices/checkout. Flip to false once one-time payments are wired to gate premium behind a purchased session.
BUDGETSPACE_BETA_MODE=true
# Free saved-plan cap. Keep high during the free beta so a user is never blocked from saving.
BUDGETSPACE_PLUS_FREE_SAVED_LIMIT=1000

# --- AI / LLM (BACKEND ONLY — never expose to the frontend) ----------------------------------------------------
# Off by default → deterministic rule-based parsing, no external calls, no cost. Gemini Flash is the cheap default.
BUDGETSPACE_AI_ENABLED=false
BUDGETSPACE_LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Optional model + limits.
BUDGETSPACE_LLM_TIMEOUT_SECONDS=15
BUDGETSPACE_LLM_MAX_OUTPUT_TOKENS=700

# --- AI cost / rate guardrails ---------------------------------------------------------------------------------
# Monthly USD is the HARD wallet cap; per-day/session prevent runaway loops. Start the wallet small in prod.
BUDGETSPACE_AI_MONTHLY_BUDGET_USD=10
BUDGETSPACE_AI_MAX_REQUESTS_PER_DAY=100
BUDGETSPACE_AI_MAX_REQUESTS_PER_SESSION=10

# --- Design assistant ------------------------------------------------------------------------------------------
BUDGETSPACE_DESIGN_ASSISTANT_LLM_ENABLED=false

# --- eBay "Rabljeno" (request-time, in-memory only — NEVER persisted) ------------------------------------------
# Rotated PROD keys. Blank → eBay used-items source is dormant (no network call).
BUDGETSPACE_MARKETPLACEFEEDS_EBAY_CLIENTID=
BUDGETSPACE_MARKETPLACEFEEDS_EBAY_CLIENTSECRET=

# --- Official / partner retailer feeds (Decathlon/Pevex/Lesnina — 403, never scraped) --------------------------
# Set a real feed URL ONLY via your secret store; blank = not configured (import skipped cleanly).
BUDGETSPACE_FEED_DECATHLON_URL=
BUDGETSPACE_FEED_PEVEX_URL=
BUDGETSPACE_FEED_LESNINA_URL=

# --- Frontend build (set when building the frontend image/bundle, not the backend) -----------------------------
# VITE_API_BASE_URL=https://api.yourdomain
